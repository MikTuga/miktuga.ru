{
  "name": "tuga-feedback-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "d1:create": "wrangler d1 create tuga-feedback",
    "d1:migrate": "wrangler d1 execute tuga-feedback --file schema.sql --remote",
    "d1:migrate:local": "wrangler d1 execute tuga-feedback --file schema.sql --local",
    "kv:create": "wrangler kv namespace create tuga-feedback-rate-limit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.80.0"
  }
}
